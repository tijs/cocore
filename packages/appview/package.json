{
  "name": "@cocore/appview",
  "version": "0.1.0",
  "private": true,
  "description": "cocore AppView: firehose indexer + read API over dev.cocore.compute.* records.",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./indexer": "./src/indexer/index.ts",
    "./store": "./src/store.ts",
    "./api": "./src/api/server.ts"
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc -p . --noEmit",
    "indexer": "node --experimental-strip-types src/indexer/index.ts",
    "api": "node --experimental-strip-types src/api/server.ts"
  },
  "dependencies": {
    "@atproto/identity": "^0.4.12",
    "@atproto/sync": "^0.2.2",
    "@cocore/sdk": "workspace:*",
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@atproto/api": "^0.19.15",
    "@atproto/dev-env": "^0.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
}
