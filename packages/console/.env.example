# Public URL of this console (no trailing slash). Required for OAuth redirect
# URIs in production; local dev defaults to http://localhost:3000 when unset.
# CONSOLE_PUBLIC_URL=http://localhost:3000

# AppView read API base URL (no trailing slash).
#
# Local dev: from the repo root, `mise dev` starts infra/services (AppView on 8081) then the console.
# You usually only need this var if the AppView is not at http://localhost:8081.
#
# Manual stack (same as `mise services` / `pnpm dev:services`): AppView read API on 8081.
#
# AppView package only: `pnpm --filter @cocore/appview api` defaults to port 8080 (set
# COCORE_APPVIEW_URL or COCORE_API_PORT=8081 to match this file).
#
# If services fail with a better-sqlite3 native module error: `pnpm rebuild better-sqlite3`
COCORE_APPVIEW_URL=http://localhost:8081

# Local advisor matchmaker (WebSocket at ws://localhost:8082/v1/agent).
# `mise dev` starts this automatically; set when running services manually.
# COCORE_ADVISOR_URL=http://localhost:8082

# Bridge publish API (default :8080 when using `mise dev` / `pnpm dev:services`).
# COCORE_BRIDGE_URL=http://localhost:8080

# Must match the exchange DID in infra/services for job dispatch to settle.
# COCORE_EXCHANGE_DID=did:web:exchange.local

# Uncomment to skip dummy provider + receipt publishing when using `mise dev` (scripts/dev.sh).
# COCORE_SKIP_SEED=1

# Secret for deriving per-user browser chat encryption keys (returned only
# to the signed-in session). REQUIRED in production: when NODE_ENV=production
# the server refuses to start deriving keys unless this is set to a strong
# value of at least 32 characters (it will not fall back to a dev secret).
# Local dev uses a built-in fallback when unset. Generate with:
#   openssl rand -base64 48
# COCORE_CHAT_STORAGE_SECRET=

# cocore is a closed-loop credit system — there is no payments provider to
# configure. (The Stripe integration was removed in the closed-loop pivot.)

# --- Observability (OpenTelemetry → Honeycomb) ---
# Telemetry is a no-op until OTEL_EXPORTER_OTLP_ENDPOINT is set. These are the
# standard OTLP env vars (read by the OTel SDK), so any OTLP backend works. Set
# them on every deployed process — console, appview, services, advisor, and the
# Rust provider. See packages/o11y/README.md for details.
#
# Honeycomb (OTLP-native). Get an Ingest key: Honeycomb → Environment settings →
# API Keys. The key alone is enough: an Ingest key is scoped to ONE Honeycomb
# environment, which is how prod/dev stay separate. Within that environment
# traces + logs land in per-service datasets (by service.name) and metrics land
# in the environment's auto-managed "metrics" dataset — no x-honeycomb-dataset
# header is needed (on Environments & Services teams it does not rename the
# metrics dataset anyway).
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_INGEST_KEY
