{
  "name": "@cocore/advisor",
  "version": "0.1.0",
  "private": true,
  "description": "Advisor: WebSocket matchmaker between requesters and providers. Stateless w.r.t. receipts; everything authoritative lives on a PDS.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "node --experimental-strip-types src/main.ts",
    "test": "vitest run",
    "test:resume": "cargo build --locked --manifest-path ../../provider/Cargo.toml --example resume_fault_provider && node --experimental-strip-types scripts/provider-resume-e2e.ts",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@atcute/crypto": "^2.4.1",
    "@atcute/identity": "^1.1.5",
    "@atcute/identity-resolver": "^1.2.3",
    "@atcute/lexicons": "^1.3.1",
    "@atcute/multibase": "^1.2.0",
    "@cocore/o11y": "workspace:*",
    "@cocore/sdk": "workspace:*",
    "@effect/platform": "^0.96.2",
    "effect": "^3.21.4",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
}
